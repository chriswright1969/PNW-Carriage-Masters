<%- include('../partials/head', { title }) %>
<%- include('../partials/header') %>

<div class="wrap">
  <div class="card">
    <h1 class="section-title">Site settings</h1>
    <p class="muted">These values appear across the site. The contact form is forwarded to the email below.</p>

    <!-- IMPORTANT: keep this as a normal POST so req.body is parsed -->
    <form action="/admin/settings" method="post">
      <div class="grid-3">
        <div>
          <label for="company_name">Company name</label>
          <input id="company_name" name="company_name" type="text" value="<%= settings.company_name %>" maxlength="120"/>
        </div>
        <div>
          <label for="tagline">Tagline</label>
          <input id="tagline" name="tagline" type="text" value="<%= settings.tagline %>" maxlength="120"/>
        </div>
        <div>
          <label for="phone">Phone</label>
          <input id="phone" name="phone" type="text" value="<%= settings.phone %>" maxlength="40" placeholder="07503 608944"/>
        </div>
      </div>

      <label for="coverage">Coverage areas</label>
      <input id="coverage" name="coverage" type="text" value="<%= settings.coverage %>" maxlength="240"/>

      <hr/>

      <label for="forward_to_email">Contact form forwarding email</label>
      <input id="forward_to_email" name="forward_to_email" type="email" value="<%= settings.forward_to_email %>" maxlength="160"/>
      <div class="small muted">Subject is fixed as: <span class="code">Contact From truckhearse.co.uk Website</span></div>

      <hr/>

      <div class="grid-3">
        <div>
          <label for="facebook_link">Facebook link</label>
          <input id="facebook_link" name="facebook_link" type="url" value="<%= settings.facebook_link %>"/>
        </div>
        <div>
          <label for="instagram_link">Instagram link</label>
          <input id="instagram_link" name="instagram_link" type="url" value="<%= settings.instagram_link %>"/>
        </div>
        <div>
          <label for="tiktok_link">TikTok link</label>
          <input id="tiktok_link" name="tiktok_link" type="url" value="<%= settings.tiktok_link %>"/>
        </div>
      </div>

      <div class="grid-3" style="margin-top:10px">
        <div>
          <label for="youtube_link">YouTube link</label>
          <input id="youtube_link" name="youtube_link" type="url" value="<%= settings.youtube_link %>"/>
        </div>
        <div></div>
        <div></div>
      </div>

      <div style="height:10px"></div>
      <button class="btn" type="submit">Save settings</button>
      <a class="btn" href="/admin" style="margin-left:8px">Back</a>
    </form>

    <hr/>

    <!-- Branding form: multipart, handled by your existing /admin/branding POST -->
    <h2 id="branding" class="section-title" style="margin-top:6px;">Branding</h2>
    <p class="muted">Logo and sizing controls are saved separately.</p>

    <form action="/admin/branding" method="post" enctype="multipart/form-data">
      <div class="grid-3">
        <div>
          <label for="logo_header_h">Header logo height (px)</label>
          <input id="logo_header_h" name="logo_header_h" type="number"
                 value="<%= settings.logo_header_h || 44 %>" min="20" max="120"/>
        </div>

        <div>
          <label for="logo_pick">Choose built-in logo</label>
          <select id="logo_pick" name="logo_pick">
            <option value="">(no change)</option>
            <option value="/images/logo.svg">logo.svg</option>
            <option value="/images/logo.png">logo.png</option>
          </select>
          <div class="small muted">Built-in files live in <span class="code">/public/images</span> and are served from <span class="code">/images/...</span>.</div>
        </div>

        <div>
          <label for="logo">Or upload a new logo</label>
          <input id="logo" name="logo" type="file" accept=".svg,.png,.jpg,.jpeg,.webp"/>
          <div class="small muted">Uploads are served from <span class="code">/uploads/...</span>.</div>
        </div>
      </div>

      <!-- your /admin/branding route expects these too -->
      <input type="hidden" name="logo_home_px" value="<%= settings.logo_home_px || 600 %>">
      <input type="hidden" name="logo_home_vw" value="<%= settings.logo_home_vw || 90 %>">

      <div style="height:10px"></div>
      <button class="btn" type="submit">Save branding</button>
      <a class="btn" href="/admin/settings#branding" style="margin-left:8px">Branding section</a>
    </form>

    <hr/>
    <div class="small muted">Email delivery requires SMTP settings on the server (see README).</div>
  </div>
</div>

<%- include('../partials/footer') %>

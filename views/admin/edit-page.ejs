<%- include('../partials/head', { title }) %>
<%- include('../partials/header') %>

<div class="wrap">
  <div class="card">
    <h1 class="section-title">Edit: <%= slug %></h1>
    <p class="muted">You can use plain text (recommended) or basic HTML tags. Placeholders: <span class="code">{company_name}</span>, <span class="code">{phone}</span>, <span class="code">{address}</span>, <span class="code">{coverage}</span>.</p>

    <form action="/admin/pages/<%= slug %>" method="post">
      <label for="title">Title</label>
      <input id="title" name="title" type="text" value="<%= page.title %>" maxlength="120"/>

      <label for="content">Content</label>
      <textarea id="content" name="content" rows="12"><%= page.content %></textarea>

      <div style="height:10px"></div>
      <button class="btn" type="submit">Save</button>
      <a class="btn" href="/admin" style="margin-left:8px">Cancel</a>
    </form>
  </div>
</div>

<%- include('../partials/footer') %>

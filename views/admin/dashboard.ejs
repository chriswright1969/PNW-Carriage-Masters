<%- include('../partials/head', { title }) %>
<%- include('../partials/header') %>

<div class="wrap">
  <div class="card">
    <h1 class="section-title">Admin dashboard</h1>
    <p class="muted">Update site content, landing page media, gallery media and contact forwarding settings.</p>

    <div class="grid-3">
      <div class="notice">
        <div class="small muted">Landing page</div>
        <div style="margin-top:6px"><a class="btn" href="/admin/pages/home">Edit home page text</a></div>
        <div style="margin-top:10px"><a class="btn" href="/admin/hero-video">Hero video (upload/select/delete)</a></div>
        <div style="margin-top:6px"><a class="btn" href="/admin/home-trucks">Home truck images</a></div>
      </div>

      <div class="notice">
        <div class="small muted">Contact page</div>
        <div style="margin-top:6px"><a class="btn" href="/admin/pages/contact">Edit contact page text</a></div>
      </div>

      <div class="notice">
        <div class="small muted">Settings</div>
        <div style="margin-top:6px"><a class="btn" href="/admin/settings">Company info & social links</a></div>
      </div>
    </div>

    <div style="height:14px"></div>

    <div class="grid-3">
      <div class="notice">
        <div class="small muted">Gallery</div>
        <div style="margin-top:6px"><a class="btn" href="/admin/gallery">Manage gallery (upload/delete)</a></div>
      </div>

      <div class="notice">
        <div class="small muted">Admins</div>
        <div style="margin-top:6px"><a class="btn" href="/admin/admins">Manage admin users</a></div>
      </div>

      <div class="notice">
        <div class="small muted">Health</div>
        <div style="margin-top:6px"><a class="btn" href="/health" target="_blank" rel="noopener noreferrer">View health JSON</a></div>
      </div>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>

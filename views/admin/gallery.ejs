<%- include('../partials/head', { title }) %>
<%- include('../partials/header') %>

<%
  // featuredId is passed from server.js (fallback safe)
  const _featuredId = Number((typeof featuredId !== "undefined" && featuredId) ? featuredId : 0);
  const _message = (typeof message !== "undefined" && message) ? message : null;
  const _errorMsg = (typeof errorMsg !== "undefined" && errorMsg) ? errorMsg : null;
%>

<%
  const _featuredId = Number((typeof featuredId !== "undefined" && featuredId) ? featuredId : 0);
  const _message = (typeof message !== "undefined" && message) ? message : null;
  const _errorMsg = (typeof errorMsg !== "undefined" && errorMsg) ? errorMsg : null;
  const _renaultMagnumImg = String((settings && settings.renault_magnum_img) || "").trim();
%>

<div class="wrap">
  <div class="card">
    <h1 class="section-title">Manage gallery</h1>
    <p class="muted">Upload new photos/videos, edit captions, choose which photo shows first on the public gallery, and delete existing items.</p>

    <% if (_message) { %>
      <div class="notice ok" style="margin:0 0 16px"><%= _message %></div>
    <% } %>

    <% if (_errorMsg) { %>
      <div class="notice bad" style="margin:0 0 16px"><%= _errorMsg %></div>
    <% } %>

    <form action="/admin/upload" method="post" enctype="multipart/form-data" class="card" style="margin-bottom:16px">
      <h2 style="margin:0 0 10px">Upload</h2>

      <label for="media">File (image or video)</label>
      <input id="media" name="media" type="file" accept="image/*,video/*" required>

      <label for="caption">Caption (optional)</label>
      <input id="caption" name="caption" type="text" maxlength="200" placeholder="e.g., Black truck hearse – side view">

      <div style="height:10px"></div>
      <button class="btn" type="submit">Upload to gallery</button>
    </form>

    <div style="display:flex; align-items:center; justify-content:space-between; gap:12px; margin:0 0 10px">
      <h2 style="margin:0">Current gallery</h2>

      <form method="post" action="/admin/gallery/featured/clear"
            onsubmit="return confirm('Clear the featured (first) image on the public gallery?');"
            style="margin:0">
        <button class="btn" type="submit" <% if (!_featuredId) { %>disabled<% } %>>
          Clear first image
        </button>
      </form>
      <form method="post" action="/admin/gallery/renault-magnum/clear"
      onsubmit="return confirm('Clear the Renault Magnum page image?');"
      style="margin:0">
  <button class="btn" type="submit" <% if (!_renaultMagnumImg) { %>disabled<% } %>>
    Clear Renault image
  </button>
</form>
    </div>

    <% if (!media || !media.length) { %>
      <div class="muted">No media uploaded yet.</div>
    <% } else { %>
      <div class="thumb-grid">
        <% media.forEach(item => { %>
          <%
            const isImg = String(item.type) === "image";
            const isFeatured = isImg && _featuredId && Number(item.id) === _featuredId;
          %>

          <div class="thumb" style="overflow:hidden">
            <% if (item.type === "video") { %>
              <video src="/uploads/<%= item.filename %>" controls></video>
            <% } else { %>
              <img src="/uploads/<%= item.filename %>" alt="<%= item.caption || '' %>">
            <% } %>

            <div class="cap">
              <form method="post" action="/admin/media/<%= item.id %>/caption" style="margin:0 0 10px">
                <label for="caption-<%= item.id %>" class="small muted" style="display:block; margin-bottom:6px;">
                  Caption
                </label>

                <input
                  id="caption-<%= item.id %>"
                  name="caption"
                  type="text"
                  maxlength="200"
                  value="<%= item.caption || '' %>"
                  placeholder="Enter caption"
                  style="width:100%; margin-bottom:10px;"
                >

                <button class="btn" type="submit">Save</button>
              </form>

              <% if (isImg) { %>
                <div style="margin-top:10px; display:flex; gap:10px; align-items:center; flex-wrap:wrap">
                  <% if (isFeatured) { %>
                    <span class="small" style="padding:6px 10px; border-radius:999px; border:1px solid var(--line); background:rgba(215,180,106,0.10); color:var(--accent);">
                      First on public gallery
                    </span>
                  <% } else { %>
                    <form method="post" action="/admin/gallery/featured/<%= item.id %>" style="margin:0">
                      <button class="btn" type="submit">Make first</button>
                    </form>
                  <% } %>
                    <div style="margin-top:10px; display:flex; gap:10px; align-items:center; flex-wrap:wrap">
  <% if (_renaultMagnumImg && item.filename === _renaultMagnumImg) { %>
    <span class="small" style="padding:6px 10px; border-radius:999px; border:1px solid var(--line); background:rgba(215,180,106,0.10); color:var(--accent);">
      Renault Magnum page image
    </span>
  <% } else { %>
    <form method="post" action="/admin/gallery/renault-magnum/<%= item.id %>" style="margin:0">
      <button class="btn" type="submit">Use for Renault Magnum page</button>
    </form>
  <% } %>
</div>
                </div>
              <% } %>

              <form method="post" action="/admin/media/<%= item.id %>/delete"
                    onsubmit="return confirm('Delete this item?');"
                    style="margin-top:10px">
                <button class="btn danger" type="submit">Delete</button>
              </form>
            </div>
          </div>
        <% }) %>
      </div>
    <% } %>

    <div style="height:12px"></div>
    <a class="btn" href="/gallery">View public gallery</a>
    <a class="btn" href="/admin" style="margin-left:8px">Back</a>
  </div>
</div>

<%- include('../partials/footer') %>

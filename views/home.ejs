<%- include('partials/head', { title }) %>
<%- include('partials/header') %>

<%
  // Set your logo path here (recommended location: /public/brand/...)
  // Put the SVG file at: /public/brand/pnw-logo.svg
  // so it loads at: /public/brand/pnw-logo.svg
  const logoSrc =
    (settings && settings.logo_url && String(settings.logo_url).trim())
      ? String(settings.logo_url).trim()
      : "/public/brand/pnw-logo.png";
%>

<!-- BIG LOGO HERO -->
<section class="home-hero">
  <div class="wrap home-hero__inner">
    <img
      class="home-hero__logo"
      src="<%= logoSrc %>"
      alt="PNW Carriage Masters"
      loading="eager"
      decoding="async"
    />

    <h1 class="home-hero__title"><%= pageTitle %></h1>

    <div class="home-hero__tagline">
      Respectful, professional alternative hearse hire for unique send-offs.
    </div>

    <div class="home-hero__meta">
      <div class="meta-pill">
        <span class="small muted">Covering:</span>
        <strong><%= settings.coverage %></strong>
      </div>

      <div class="meta-pill">
        <span class="small muted">Call:</span>
        <a href="tel:<%= settings.phone.replace(/\s/g,'') %>"><%= settings.phone %></a>
      </div>
    </div>

    <div class="home-hero__cta">
      <a class="btn" href="/contact">Contact / Find us</a>
      <a class="btn btn-outline" href="/gallery">View gallery</a>
    </div>
  </div>
</section>

<!-- CONTENT + VEHICLES (clean split) -->
<div class="wrap">
  <div class="home-split">
    <div class="card home-copy">
      <div><%- contentHtml %></div>
    </div>

    <div class="card">
      <h2 class="section-title">Our vehicles</h2>
      <ul class="muted">
        <li>Bespoke truck hearse</li>
        <li>Classic black Rolls-Royce hearse & limousine</li>
        <li>Classic white Daimler hearse & limousine</li>
      </ul>
      <hr/>
      <div class="muted small">
        Discreet service, immaculate presentation, and considerate support for families and funeral directors.
      </div>
    </div>
  </div>
</div>

<!-- 3 KEY POINTS -->
<div class="wrap">
  <div class="grid-3">
    <div class="card">
      <h3 class="section-title">Sombre & professional</h3>
      <div class="muted">A calm, respectful presence on the day — your arrangements carried out with care.</div>
    </div>
    <div class="card">
      <h3 class="section-title">Flexible hire</h3>
      <div class="muted">Work with us directly or through your funeral director to suit the service.</div>
    </div>
    <div class="card">
      <h3 class="section-title">Local coverage</h3>
      <div class="muted">North Wales, Chester, Wrexham, Shrewsbury, Liverpool, Wirral and Warrington.</div>
    </div>
  </div>
</div>

<%- include('partials/footer') %>

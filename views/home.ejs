<%- include('partials/head', { title }) %>
<%- include('partials/header') %>

<%
  const s = settings || {};
  const heroFile = s.hero_video_current || "";
  const heroVer  = s.hero_video_version || "";
  const phoneRaw = String(s.phone || "").trim();
  const phoneTel = phoneRaw.replace(/\s+/g, "");
%>
<div class="wrap home">
  <section class="hero">
    <div class="hero-media">
  <div class="hero-media-stack">
    <% if (heroFile) { %>
      <video class="hero-video" autoplay muted loop playsinline controls>
        <source src="/uploads/<%= heroFile %>?v=<%= heroVer %>">
      </video>
    <% } else { %>
      <div class="hero-fallback"><div class="muted">No hero video selected.</div></div>
    <% } %>

    <%
      const powerFile = String(s.home_truck_power_img || "").trim();
      const gloryFile = String(s.home_truck_glory_img || "").trim();
      const powerVer  = String(s.home_truck_power_ver || "").trim();
      const gloryVer  = String(s.home_truck_glory_ver || "").trim();
    %>

    <div class="hero-truck-grid">
      <figure class="hero-truck-card">
        <a href="/gallery" class="hero-truck-link">
          <% if (powerFile) { %>
            <img src="/uploads/<%= powerFile %>?v=<%= powerVer %>" alt="The Power — truck hearse">
          <% } else { %>
            <div class="hero-truck-fallback">
              <div class="muted">Image placeholder</div>
              <div class="hero-truck-name">The Power</div>
            </div>
          <% } %>
        </a>
        <figcaption>The Power</figcaption>
      </figure>

      <figure class="hero-truck-card">
        <a href="/gallery" class="hero-truck-link">
          <% if (gloryFile) { %>
            <img src="/uploads/<%= gloryFile %>?v=<%= gloryVer %>" alt="The Glory — truck hearse">
          <% } else { %>
            <div class="hero-truck-fallback">
              <div class="muted">Image placeholder</div>
              <div class="hero-truck-name">The Glory</div>
            </div>
          <% } %>
        </a>
        <figcaption>The Glory</figcaption>
      </figure>
    </div>
  </div>
</div>

<div class="hero-truck-grid">
  <figure class="hero-truck-card">
    <a href="/gallery" class="hero-truck-link" title="Open gallery">
      <% if (powerFile) { %>
        <img src="/uploads/<%= powerFile %>?v=<%= powerVer %>" alt="The Power — truck hearse">
      <% } else { %>
        <div class="hero-truck-fallback">
          <div class="muted">Image placeholder</div>
          <div class="hero-truck-name">The Power</div>
        </div>
      <% } %>
    </a>
    <figcaption>The Power</figcaption>
  </figure>

  <figure class="hero-truck-card">
    <a href="/gallery" class="hero-truck-link" title="Open gallery">
      <% if (gloryFile) { %>
        <img src="/uploads/<%= gloryFile %>?v=<%= gloryVer %>" alt="The Glory — truck hearse">
      <% } else { %>
        <div class="hero-truck-fallback">
          <div class="muted">Image placeholder</div>
          <div class="hero-truck-name">The Glory</div>
        </div>
      <% } %>
    </a>
    <figcaption>The Glory</figcaption>
  </figure>
</div>
    <div class="hero-copy">
      <h1><%= pageTitle %></h1>
      <div class="lead">Exclusive truck hearse hire for unique send-offs.</div>

      <div class="cta">
        <a class="btn" href="/gallery">Photo gallery</a>
        <a class="btn" href="/contact">Enquire</a>
        <% if (phoneTel) { %>
          <a class="btn" href="tel:<%= phoneTel %>">Call <%= phoneRaw %></a>
        <% } %>
      </div>

      <div class="rich"><%- contentHtml %></div>
    </div>
  </section>

  <% if (thumbs && thumbs.length) { %>
    <section class="thumbs">
      <h2>Our truck hearses</h2>
      <div class="thumb-grid">
        <% thumbs.forEach(fn => { %>
          <a class="thumb" href="/gallery" title="Open gallery">
            <img src="/uploads/<%= fn %>" alt="Truck hearse">
          </a>
        <% }) %>
      </div>
    </section>
  <% } %>

  <% if (montage && montage.length) { %>
    <section class="montage">
      <div class="marquee">
        <div class="marquee-track">
          <% montage.concat(montage).forEach(fn => { %>
            <img src="/uploads/<%= fn %>" alt="Montage image">
          <% }) %>
        </div>
      </div>
    </section>
  <% } %>
</div>

<%- include('partials/footer') %>

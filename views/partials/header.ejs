<header class="site-header">
  <div class="header-inner">
    <%
      // Always guard against settings being undefined (otherwise EJS can throw)
      const s = (typeof settings !== "undefined" && settings) ? settings : {};

      const logoFile = String(s.logo_file || "").trim();
      const logoVer  = String(s.logo_version || "").trim();
      const verQ     = logoVer ? `?v=${encodeURIComponent(logoVer)}` : "";

      // If logo_file starts with "/", treat it as a direct path (e.g. "/images/logo.svg")
      // Otherwise treat it as an uploaded filename under /uploads
      const logoSrc = logoFile
        ? (logoFile.startsWith("/") ? `${logoFile}${verQ}` : `/uploads/${logoFile}${verQ}`)
        : "/images/logo.svg";

      // Safe header height (px)
      const headerHRaw = Number(s.logo_header_h || 44);
      const headerH = Number.isFinite(headerHRaw) ? Math.min(120, Math.max(20, headerHRaw)) : 44;

      const companyName = String(s.company_name || "PNW Carriage Masters");
      const tagline = String(s.tagline || "");
    %>

    <a class="brand" href="/" aria-label="Home">
      <img
        src="<%= logoSrc %>"
        alt="<%= companyName %> logo"
        style="height:<%= headerH %>px; width:auto;"
      />
      <div class="brand-text">
        <div class="name"><%= companyName %></div>
        <div class="tag"><%= tagline %></div>
      </div>
    </a>

    <nav aria-label="Primary">
      <a href="/" class="pill">Home</a>
      <a href="/gallery" class="pill">Gallery</a>
      <a href="/contact" class="pill">Contact</a>
      <% if (admin) { %>
        <a href="/admin" class="pill">Admin</a>
        <form action="/logout" method="post" style="display:inline">
          <button class="btn" type="submit" style="margin-left:10px">Log out</button>
        </form>
      <% } else { %>
        <a href="/login" class="pill">Admin login</a>
      <% } %>
    </nav>
  </div>
</header>

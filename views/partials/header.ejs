<header class="site-header">
  <div class="header-inner">
    <%
      // Use admin-changeable logo if set, otherwise fall back to /images/logo.png
      const logoFile = (settings && settings.logo_file) ? String(settings.logo_file) : "";
      const logoVer  = (settings && settings.logo_version) ? String(settings.logo_version) : "";
      const logoSrc  = logoFile ? (`/uploads/${logoFile}${logoVer ? `?v=${logoVer}` : ""}`) : "/images/logo.png";

      // Admin-changeable header logo height (px)
      const headerH = Number(settings?.logo_header_h || 44);
    %>

    <a class="brand" href="/" aria-label="Home">
      <img
        src="<%= logoSrc %>"
        alt="<%= settings.company_name %> logo"
        style="height:<%= headerH %>px; width:auto;"
      />
      <div class="brand-text">
        <div class="name"><%= settings.company_name %></div>
        <div class="tag"><%= settings.tagline %></div>
      </div>
    </a>

    <nav aria-label="Primary">
      <a href="/" class="pill">Home</a>
      <a href="/gallery" class="pill">Gallery</a>
      <a href="/contact" class="pill">Contact</a>
      <% if (admin) { %>
        <a href="/admin" class="pill">Admin</a>
        <form action="/logout" method="post" style="display:inline">
          <button class="btn" type="submit" style="margin-left:10px">Log out</button>
        </form>
      <% } else { %>
        <a href="/login" class="pill">Admin login</a>
      <% } %>
    </nav>
  </div>
</header>

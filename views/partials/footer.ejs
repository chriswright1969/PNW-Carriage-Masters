<footer class="footer">
  <div class="wrap">
    <%
      const s = settings || {};
      const phoneRaw = String(s.phone || "").trim();
      const phoneTel = phoneRaw.replace(/\s+/g, "");
      const has = (v) => String(v || "").trim().length > 0;
    %>

    <div class="muted" style="text-align:center">
      <div><strong><%= s.company_name %></strong> — <%= s.tagline %></div>

      <% if (phoneTel) { %>
        <div style="margin-top:6px">
          Phone: <a href="tel:<%= phoneTel %>"><%= phoneRaw %></a>
        </div>
      <% } %>

      <div class="small" style="margin-top:6px">Serving <%= s.coverage %></div>

      <div class="socials" style="margin-top:14px">
        <% if (has(s.facebook_link)) { %>
          <a class="social-icon" href="<%= s.facebook_link %>" target="_blank" rel="noopener noreferrer" aria-label="Facebook" title="Facebook">
            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M13.5 22v-8h2.7l.4-3H13.5V9.1c0-.9.3-1.5 1.6-1.5h1.6V5a22 22 0 0 0-2.3-.1c-2.3 0-3.9 1.4-3.9 4V11H8v3h2.6v8h2.9z"/></svg>
          </a>
        <% } %>

        <% if (has(s.tiktok_link)) { %>
  <a class="social-icon" href="<%= s.tiktok_link %>" target="_blank" rel="noopener noreferrer" aria-label="TikTok" title="TikTok">
    <svg viewBox="0 0 24 24" aria-hidden="true">
      <path d="M19.589 6.686a4.793 4.793 0 0 1-3.77-4.187V2h-3.028v13.273a2.896 2.896 0 1 1-2.896-2.896c.226 0 .447.027.659.078V9.39a5.924 5.924 0 0 0-.659-.036A5.93 5.93 0 1 0 15.82 15.28V8.544a7.827 7.827 0 0 0 4.58 1.479V6.995c-.278 0-.551-.103-.811-.309z"/>
    </svg>
  </a>
<% } %>

        <% if (has(s.tiktok_link)) { %>
          <a class="social-icon" href="<%= s.tiktok_link %>" target="_blank" rel="noopener noreferrer" aria-label="TikTok" title="TikTok">
            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M14 3v10.1a3.6 3.6 0 1 1-3-3.5V6.2c.7.8 1.6 1.4 2.7 1.8.9.4 1.9.6 3.3.6V6.1c-1.2 0-2.2-.4-3-1.1-.8-.7-1.3-1.6-1.4-2zM10.4 12.8a1.9 1.9 0 1 0 0 3.8 1.9 1.9 0 0 0 0-3.8z"/></svg>
          </a>
        <% } %>

        <% if (has(s.youtube_link)) { %>
          <a class="social-icon" href="<%= s.youtube_link %>" target="_blank" rel="noopener noreferrer" aria-label="YouTube" title="YouTube">
            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M21.6 7.2a3 3 0 0 0-2.1-2.1C17.7 4.6 12 4.6 12 4.6s-5.7 0-7.5.5A3 3 0 0 0 2.4 7.2 31 31 0 0 0 2 12a31 31 0 0 0 .4 4.8 3 3 0 0 0 2.1 2.1c1.8.5 7.5.5 7.5.5s5.7 0 7.5-.5a3 3 0 0 0 2.1-2.1A31 31 0 0 0 22 12a31 31 0 0 0-.4-4.8zM10 15.5v-7l6 3.5-6 3.5z"/></svg>
          </a>
        <% } %>

        <a class="social-icon" href="/contact" aria-label="Email / Contact" title="Email">
          <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M4 6h16a2 2 0 0 1 2 2v10a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2zm0 2v.2l8 5.3 8-5.3V8H4zm16 10V10l-8 5.3L4 10v8h16z"/></svg>
        </a>
      </div>

      <div class="small" style="margin-top:12px">© <%= new Date().getFullYear() %> <%= s.company_name %></div>
    </div>
  </div>
</footer>
</body>
</html>

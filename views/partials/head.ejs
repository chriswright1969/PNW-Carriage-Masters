<!doctype html>
<html lang="en-GB">
<head>
  <%
    const siteName = "PNW Carriage Masters";
    const siteUrl = "https://www.truckhearse.co.uk";
    const defaultDescription =
      "Bespoke truck hearse and lorry hearse hire across the UK. Alternative funeral transport by PNW Carriage Masters, exclusive for the funeral profession. Contact us directly for a quote.";
    const defaultImage = `${siteUrl}/images/logo.svg`;

    const pageTitle = String(
      (typeof metaTitle !== "undefined" && metaTitle) ? metaTitle : (title || siteName)
    ).trim();

    const pageDescription = String(
      (typeof metaDescription !== "undefined" && metaDescription) ? metaDescription : defaultDescription
    ).trim();

    const pageImage = String(
      (typeof metaImage !== "undefined" && metaImage) ? metaImage : defaultImage
    ).trim();

    const hasCanonical = (typeof canonicalPath !== "undefined" && canonicalPath !== null);
    const canonicalUrl = hasCanonical
      ? `${siteUrl}${String(canonicalPath).trim()}`
      : "";

    const robotsContent =
      (typeof metaRobots !== "undefined" && metaRobots)
        ? String(metaRobots).trim()
        : (hasCanonical ? "index,follow" : "");

    const isHomePage = canonicalUrl === `${siteUrl}/`;

    const settingsSafe = (typeof settings !== "undefined" && settings) ? settings : {};

    const phoneRaw = String(settingsSafe.phone || "").trim();
    const phoneDigits = phoneRaw.replace(/[^\d+]/g, "");
    const phoneValue = phoneDigits.startsWith("+")
      ? phoneDigits
      : (phoneDigits.startsWith("0") ? `+44${phoneDigits.slice(1)}` : phoneDigits);

    const businessAddress = {
      streetAddress: String(settingsSafe.street_address || "").trim(),
      addressLocality: String(settingsSafe.address_locality || "").trim(),
      addressRegion: String(settingsSafe.address_region || "").trim(),
      postalCode: String(settingsSafe.postal_code || "").trim(),
      addressCountry: String(settingsSafe.address_country || "GB").trim()
    };

    const hasPublicAddress =
      businessAddress.streetAddress &&
      businessAddress.addressLocality &&
      businessAddress.postalCode &&
      businessAddress.addressCountry;

    const sameAs = [
      "https://www.facebook.com/PNWCarriageMasters",
      "https://www.instagram.com/pnwcarriagemasters/",
      "https://www.tiktok.com/@truckhearse",
      "https://www.youtube.com/@pnwcarriagemasters1612"
    ];

    const siteGraph = [];

    if (isHomePage) {
      siteGraph.push({
        "@type": "Organization",
        "@id": `${siteUrl}/#organization`,
        "name": siteName,
        "url": siteUrl,
        "logo": {
          "@type": "ImageObject",
          "url": defaultImage
        },
        "image": defaultImage,
        "description": defaultDescription,
        ...(phoneValue ? { "telephone": phoneValue } : {}),
        ...(phoneValue ? {
          "contactPoint": {
            "@type": "ContactPoint",
            "contactType": "customer service",
            "telephone": phoneValue
          }
        } : {}),
        "sameAs": sameAs,
        "areaServed": {
          "@type": "Country",
          "name": "United Kingdom"
        }
      });

      siteGraph.push({
        "@type": "WebSite",
        "@id": `${siteUrl}/#website`,
        "name": siteName,
        "url": siteUrl,
        "publisher": {
          "@id": `${siteUrl}/#organization`
        }
      });

      if (hasPublicAddress) {
        siteGraph.push({
          "@type": "LocalBusiness",
          "@id": `${siteUrl}/#localbusiness`,
          "name": siteName,
          "url": siteUrl,
          "image": defaultImage,
          "logo": defaultImage,
          "description": defaultDescription,
          ...(phoneValue ? { "telephone": phoneValue } : {}),
          "address": {
            "@type": "PostalAddress",
            "streetAddress": businessAddress.streetAddress,
            "addressLocality": businessAddress.addressLocality,
            ...(businessAddress.addressRegion ? { "addressRegion": businessAddress.addressRegion } : {}),
            "postalCode": businessAddress.postalCode,
            "addressCountry": businessAddress.addressCountry
          },
          "sameAs": sameAs,
          "areaServed": {
            "@type": "Country",
            "name": "United Kingdom"
          },
          "parentOrganization": {
            "@id": `${siteUrl}/#organization`
          }
        });
      }
    }

    const siteStructuredData = siteGraph.length
      ? JSON.stringify({
          "@context": "https://schema.org",
          "@graph": siteGraph
        }).replace(/</g, "\\u003c")
      : "";

    const pageStructuredData =
      (typeof structuredData !== "undefined" && structuredData)
        ? JSON.stringify(structuredData).replace(/</g, "\\u003c")
        : "";

    const breadcrumbItems =
      (typeof breadcrumbs !== "undefined" && Array.isArray(breadcrumbs))
        ? breadcrumbs.filter(b => b && String(b.name || "").trim())
        : [];

    const breadcrumbStructuredData =
      (breadcrumbItems.length > 1)
        ? JSON.stringify({
            "@context": "https://schema.org",
            "@type": "BreadcrumbList",
            "itemListElement": breadcrumbItems.map((b, i) => {
              const href = String(b.href || "").trim();
              return {
                "@type": "ListItem",
                "position": i + 1,
                "name": String(b.name).trim(),
                ...(href ? { "item": `${siteUrl}${href}` } : {})
              };
            })
          }).replace(/</g, "\\u003c")
        : "";
  %>

  <meta charset="utf-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1"/>
  <meta name="theme-color" content="#0b0f14"/>

  <title><%= pageTitle %></title>
  <meta name="description" content="<%= pageDescription %>"/>

  <% if (robotsContent) { %>
    <meta name="robots" content="<%= robotsContent %>"/>
  <% } %>

  <% if (hasCanonical) { %>
    <link rel="canonical" href="<%= canonicalUrl %>"/>
  <% } %>

  <meta property="og:type" content="website"/>
  <meta property="og:site_name" content="<%= siteName %>"/>
  <meta property="og:title" content="<%= pageTitle %>"/>
  <meta property="og:description" content="<%= pageDescription %>"/>
  <meta property="og:image" content="<%= pageImage %>"/>
  <% if (hasCanonical) { %>
    <meta property="og:url" content="<%= canonicalUrl %>"/>
  <% } %>

  <meta name="twitter:card" content="summary_large_image"/>
  <meta name="twitter:title" content="<%= pageTitle %>"/>
  <meta name="twitter:description" content="<%= pageDescription %>"/>
  <meta name="twitter:image" content="<%= pageImage %>"/>

  <link rel="stylesheet" href="/css/site.css"/>
  <link rel="icon" href="/images/logo.svg"/>

  <% if (siteStructuredData) { %>
    <script type="application/ld+json"><%- siteStructuredData %></script>
  <% } %>

  <% if (pageStructuredData) { %>
    <script type="application/ld+json"><%- pageStructuredData %></script>
  <% } %>

  <% if (breadcrumbStructuredData) { %>
    <script type="application/ld+json"><%- breadcrumbStructuredData %></script>
  <% } %>
</head>
<body>

<!doctype html>
<html lang="en-GB">
<head>
  <%
    const siteName = "PNW Carriage Masters";
    const siteUrl = "https://www.truckhearse.co.uk";
    const defaultDescription =
      "Bespoke truck hearse and lorry hearse hire across the UK. Alternative funeral transport by PNW Carriage Masters, exclusive for the funeral profession. Contact us direct for a quote.";
    const defaultImage = `${siteUrl}/images/logo.svg`;

    const pageTitle = String(
      (typeof metaTitle !== "undefined" && metaTitle) ? metaTitle : (title || siteName)
    ).trim();

    const pageDescription = String(
      (typeof metaDescription !== "undefined" && metaDescription) ? metaDescription : defaultDescription
    ).trim();

    const pageImage = String(
      (typeof metaImage !== "undefined" && metaImage) ? metaImage : defaultImage
    ).trim();

    const hasCanonical = (typeof canonicalPath !== "undefined" && canonicalPath !== null);
    const canonicalUrl = hasCanonical
      ? `${siteUrl}${String(canonicalPath).trim()}`
      : "";

    /*
      Safe behaviour:
      - If a page passes metaRobots, use it.
      - Else, if a canonicalPath is provided, assume it is a public SEO page and allow indexing.
      - Else output no robots tag at all, so existing admin/shared pages are not changed unexpectedly.
    */
    const robotsContent =
      (typeof metaRobots !== "undefined" && metaRobots)
        ? String(metaRobots).trim()
        : (hasCanonical ? "index,follow" : "");

    /*
      Only emit structured data for the homepage by default.
      This avoids changing admin pages or other shared pages unexpectedly.
    */
    const isHomePage = canonicalUrl === `${siteUrl}/`;

    const phoneValue =
      (typeof settings !== "undefined" && settings && settings.phone)
        ? String(settings.phone).trim()
        : undefined;

    const jsonLd = isHomePage
      ? JSON.stringify(
          [
            {
              "@context": "https://schema.org",
              "@type": "Organization",
              "name": siteName,
              "url": siteUrl,
              "logo": defaultImage,
              "telephone": phoneValue,
              "description": defaultDescription
            },
            {
              "@context": "https://schema.org",
              "@type": "WebSite",
              "name": siteName,
              "url": siteUrl
            }
          ],
          null,
          2
        ).replace(/</g, "\\u003c")
      : "";
  %>

  <meta charset="utf-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1"/>
  <meta name="theme-color" content="#0b0f14"/>

  <title><%= pageTitle %></title>
  <meta name="description" content="<%= pageDescription %>"/>

  <% if (robotsContent) { %>
    <meta name="robots" content="<%= robotsContent %>"/>
  <% } %>

  <% if (hasCanonical) { %>
    <link rel="canonical" href="<%= canonicalUrl %>"/>
  <% } %>

  <meta property="og:type" content="website"/>
  <meta property="og:site_name" content="<%= siteName %>"/>
  <meta property="og:title" content="<%= pageTitle %>"/>
  <meta property="og:description" content="<%= pageDescription %>"/>
  <meta property="og:image" content="<%= pageImage %>"/>
  <% if (hasCanonical) { %>
    <meta property="og:url" content="<%= canonicalUrl %>"/>
  <% } %>

  <meta name="twitter:card" content="summary_large_image"/>
  <meta name="twitter:title" content="<%= pageTitle %>"/>
  <meta name="twitter:description" content="<%= pageDescription %>"/>
  <meta name="twitter:image" content="<%= pageImage %>"/>

  <link rel="stylesheet" href="/css/site.css"/>
  <link rel="icon" href="/images/logo.svg"/>

  <% if (jsonLd) { %>
    <script type="application/ld+json"><%- jsonLd %></script>
  <% } %>
</head>
<body>

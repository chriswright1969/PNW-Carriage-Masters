<%
  const breadcrumbs = [
    { name: "Home", href: "/" },
    { name: "Gallery", href: "/gallery" }
  ];
%>

<%- include('partials/head', {
  title,
  metaTitle: 'Truck Hearse Gallery | Renault Magnum & ERF EC12 Funeral Hire',
  metaDescription: 'Explore our truck hearse gallery with photos and videos of the Renault Magnum and ERF EC12 specialist funeral vehicles available across the UK.',
  canonicalPath: '/gallery'
}) %>
<%- include('partials/header') %>

<%
  const items = Array.isArray(media) ? media : [];

  const isVideo = (it) => (it && String(it.type) === "video");
  const srcOf = (it) => it ? `/uploads/${it.filename}` : "";
  const clean = (v) => String(v || "").trim();
  const compact = (v) => clean(v).replace(/\s+/g, " ").trim();
  const lower = (v) => compact(v).toLowerCase();
  const wordCount = (v) => compact(v).split(/\s+/).filter(Boolean).length;

  // SEO text for known videos
  const videoMeta = {
    "1773063068894-c678c01226fd.mp4": {
      title: "ERF EC12 Hearse Video",
      description:
        "This video shows our ERF EC12 hearse, a distinctive lorry hearse available for funeral directors and families seeking alternative hearse hire and specialist funeral transport in the UK."
    },

    "1773063489300-3b34ad870659.mp4": {
      title: "Renault Magnum Truck Hearse Video",
      description:
        "Watch our Renault Magnum truck hearse in action. This bespoke alternative hearse is available for funeral hire across the UK and offers a personal, respectful and memorable final journey."
    },

    "1773063202508-38b2b68e1d4d.mp4": {
      title: "Truck Hearse Funeral Transport Video",
      description:
        "See our bespoke truck hearse providing unique funeral transport in the UK. This alternative hearse is ideal for families wanting a final journey that reflects a life connected with trucks, haulage or the road."
    },

    "1773062895067-c0dad5586606.mp4": {
      title: "Alternative Hearse Hire Video",
      description:
        "This gallery video shows our custom truck hearse service for funerals across the UK. It is a professional alternative hearse hire option for a truly personal and dignified final journey."
    },

    "1773062773652-48134637eeef.mp4": {
      title: "Lorry Hearse Hire UK Video",
      description:
        "Discover specialist lorry hearse hire in the UK, including our unique funeral vehicles designed for families and funeral directors looking for a distinctive alternative to a traditional hearse."
    }
  };

  function classifyVehicle(it) {
    const haystack = [
      clean(it && it.filename),
      clean(it && it.title),
      clean(it && it.caption),
      clean(it && it.description)
    ].join(" ").toLowerCase();

    if (/(renault|magnum)/.test(haystack)) return "renault";
    if (/(erf|ec12)/.test(haystack)) return "erf";
    return "generic";
  }

  function seoImageMeta(it) {
    const vehicle = classifyVehicle(it);

    if (vehicle === "renault") {
      return {
        title: "Renault Magnum truck hearse",
        description:
          "Photo of our Renault Magnum truck hearse, available for specialist funeral hire across the UK.",
        alt: "Renault Magnum truck hearse for specialist funeral hire in the UK"
      };
    }

    if (vehicle === "erf") {
      return {
        title: "ERF EC12 lorry hearse",
        description:
          "Photo of our ERF EC12 lorry hearse, available for bespoke funeral transport across the UK.",
        alt: "ERF EC12 lorry hearse for bespoke funeral transport in the UK"
      };
    }

    return {
      title: "Truck hearse",
      description:
        "Photo from our truck hearse gallery showing specialist funeral transport available across the UK.",
      alt: "Truck hearse for specialist funeral transport in the UK"
    };
  }

  function isStrongLiteralText(text) {
    const t = compact(text);
    const l = lower(text);

    if (!t) return false;
    if (wordCount(t) < 4 || wordCount(t) > 28) return false;

    const weakPhrases = [
      "the final journey",
      "lest we forget",
      "anyway the wind blows",
      "gallery image",
      "gallery photo",
      "open image",
      "open video"
    ];

    if (weakPhrases.some((p) => l.includes(p))) return false;

    return /(truck hearse|lorry hearse|hearse|funeral|renault|magnum|erf|ec12|transport|vehicle)/i.test(t);
  }

  function metaOf(it) {
    if (!it) {
      return {
        title: "",
        description: "",
        alt: "Truck hearse for specialist funeral hire in the UK"
      };
    }

    const filename = clean(it.filename);

    if (isVideo(it) && videoMeta[filename]) {
      return {
        title: videoMeta[filename].title,
        description: videoMeta[filename].description,
        alt: videoMeta[filename].title
      };
    }

    const seo = seoImageMeta(it);

    const adminTitle = compact(it.title);
    const adminDescription = compact(it.caption) || compact(it.description);

    return {
      title: isStrongLiteralText(adminTitle) ? adminTitle : seo.title,
      description: isStrongLiteralText(adminDescription) ? adminDescription : seo.description,
      alt: seo.alt
    };
  }

  // Prefer first IMAGE for the "main" display; fall back to first item
  const firstImage = items.find(it => it && String(it.type) === "image") || null;
  const first = firstImage || items[0] || null;
  const firstFilename = first ? String(first.filename) : "";
  const firstMeta = metaOf(first);
%>

<div class="wrap gallery">
  <%- include('partials/breadcrumbs', { breadcrumbs }) %>

  <h1>Truck Hearse Gallery</h1>

  <div class="card gallery-intro-card">
    <p>
      Explore our truck hearse and lorry hearse gallery, including specialist funeral transport available across the UK.
      This page includes images and videos of our bespoke vehicles, including the Renault Magnum truck hearse and ERF EC12 lorry hearse,
      created for funeral directors and families seeking a more personal and memorable final journey.
    </p>
    <p>
      For many families, a truck hearse is chosen because it reflects a lifetime connected to haulage, transport, engineering or the road.
      Our gallery shows how these specialist vehicles can provide a dignified and fitting tribute.
    </p>
  </div>

  <div class="gallery-links-grid">
    <div class="card">
      <h2 style="margin-top:0;">Renault Magnum</h2>
      <p style="margin-bottom:14px;">
        Learn more about our Renault Magnum truck hearse and why it is chosen for distinctive, personal funerals.
      </p>
      <a class="btn" href="/renault-magnum-hearse">View Renault Magnum</a>
    </div>

    <div class="card">
      <h2 style="margin-top:0;">ERF EC12</h2>
      <p style="margin-bottom:14px;">
        Explore our ERF EC12 lorry hearse, a striking specialist vehicle for a final journey connected to the road.
      </p>
      <a class="btn" href="/erf-ec12-hearse">View ERF EC12</a>
    </div>

    <div class="card">
      <h2 style="margin-top:0;">Case Studies</h2>
      <p style="margin-bottom:14px;">
        Read recent field updates and completed service examples showing our hearses out on real funeral work.
      </p>
      <a class="btn" href="/case-studies">View case studies</a>
    </div>

    <div class="card">
      <h2 style="margin-top:0;">Need availability?</h2>
      <p style="margin-bottom:14px;">
        Contact us directly for availability, vehicle options and UK coverage for upcoming funeral requirements.
      </p>
      <a class="btn" href="/contact">Contact us</a>
    </div>
  </div>

  <% if (!items.length) { %>
    <div class="card"><div class="muted">No gallery items yet.</div></div>
  <% } else { %>

    <div class="gallery-main" id="galleryMain">
      <% if (first && isVideo(first)) { %>
        <video controls playsinline preload="metadata" class="gallery-media">
          <source src="<%= srcOf(first) %>">
        </video>
      <% } else { %>
        <img
          class="gallery-media"
          src="<%= srcOf(first) %>"
          alt="<%= firstMeta.alt %>"
          decoding="async"
          fetchpriority="high"
        >
      <% } %>
    </div>

    <div
      class="card gallery-section-card"
      id="galleryMeta"
      style="<%= (firstMeta.title || firstMeta.description) ? '' : 'display:none;' %>"
    >
      <h2
        id="galleryTitle"
        class="gallery-meta-title"
        style="<%= firstMeta.title ? '' : 'display:none;' %>"
      ><%= firstMeta.title %></h2>

      <p
        id="galleryDescription"
        class="gallery-meta-description"
        style="<%= firstMeta.description ? '' : 'display:none;' %>"
      ><%= firstMeta.description %></p>
    </div>

    <div class="gallery-strip-wrap">
      <button
        type="button"
        class="gallery-arrow gallery-arrow-left"
        id="galleryArrowLeft"
        aria-label="Previous thumbnails"
      >
        &#10094;
      </button>

      <div class="gallery-strip-viewport">
        <div class="gallery-strip" id="galleryStrip">
          <% items.forEach((it) => {
            const meta = metaOf(it);
          %>
            <button
              type="button"
              class="gthumb <%= String(it.filename) === firstFilename ? 'active' : '' %>"
              data-type="<%= it.type %>"
              data-src="<%= srcOf(it) %>"
              data-title="<%= meta.title %>"
              data-description="<%= meta.description %>"
              data-alt="<%= meta.alt %>"
              aria-label="<%= meta.title || (it.type === 'video' ? 'Open video' : 'Open image') %>"
              title="<%= meta.title || meta.description || (it.type === 'video' ? 'Open video' : 'Open image') %>"
            >
              <% if (isVideo(it)) { %>
                <video muted playsinline preload="metadata">
                  <source src="<%= srcOf(it) %>">
                </video>
                <span class="gthumb-badge">VIDEO</span>
              <% } else { %>
                <img
                  src="<%= srcOf(it) %>"
                  alt="<%= meta.alt %>"
                  loading="lazy"
                  decoding="async"
                >
              <% } %>
            </button>
          <% }) %>
        </div>
      </div>

      <button
        type="button"
        class="gallery-arrow gallery-arrow-right"
        id="galleryArrowRight"
        aria-label="Next thumbnails"
      >
        &#10095;
      </button>
    </div>

    <script>
      (function () {
        const main = document.getElementById("galleryMain");
        const strip = document.getElementById("galleryStrip");
        const leftBtn = document.getElementById("galleryArrowLeft");
        const rightBtn = document.getElementById("galleryArrowRight");
        const metaWrap = document.getElementById("galleryMeta");
        const titleEl = document.getElementById("galleryTitle");
        const descEl = document.getElementById("galleryDescription");

        if (!main || !strip || !leftBtn || !rightBtn || !metaWrap || !titleEl || !descEl) return;

        function updateArrowState() {
          const maxScroll = strip.scrollWidth - strip.clientWidth;
          const current = strip.scrollLeft;

          leftBtn.disabled = current <= 4;
          rightBtn.disabled = current >= (maxScroll - 4);
        }

        function scrollStrip(direction) {
          const step = Math.max(220, Math.round(strip.clientWidth * 0.7));
          strip.scrollBy({
            left: direction * step,
            behavior: "smooth"
          });
        }

        function updateMeta(title, description) {
          const hasTitle = !!(title && title.trim());
          const hasDescription = !!(description && description.trim());

          titleEl.textContent = hasTitle ? title : "";
          descEl.textContent = hasDescription ? description : "";

          titleEl.style.display = hasTitle ? "" : "none";
          descEl.style.display = hasDescription ? "" : "none";
          metaWrap.style.display = (hasTitle || hasDescription) ? "" : "none";
        }

        function renderSelected(type, src, altText, title, description) {
          main.innerHTML = "";

          if (type === "video") {
            const video = document.createElement("video");
            video.className = "gallery-media";
            video.controls = true;
            video.playsInline = true;
            video.preload = "metadata";

            const source = document.createElement("source");
            source.src = src;

            video.appendChild(source);
            main.appendChild(video);
          } else {
            const img = document.createElement("img");
            img.className = "gallery-media";
            img.src = src;
            img.alt = altText || title || "Truck hearse for specialist funeral hire in the UK";
            img.decoding = "async";
            main.appendChild(img);
          }

          updateMeta(title, description);
        }

        leftBtn.addEventListener("click", function () {
          scrollStrip(-1);
        });

        rightBtn.addEventListener("click", function () {
          scrollStrip(1);
        });

        strip.addEventListener("click", function (e) {
          const btn = e.target.closest(".gthumb");
          if (!btn) return;

          strip.querySelectorAll(".gthumb").forEach(x => x.classList.remove("active"));
          btn.classList.add("active");

          const type = btn.dataset.type || "";
          const src = btn.dataset.src || "";
          const title = btn.dataset.title || "";
          const description = btn.dataset.description || "";
          const alt = btn.dataset.alt || "";

          renderSelected(type, src, alt, title, description);
        });

        strip.addEventListener("scroll", updateArrowState);
        window.addEventListener("resize", updateArrowState);

        updateArrowState();
      })();
    </script>

    <div class="card gallery-section-card gallery-narrow-card">
      <h2 class="gallery-section-title">Our specialist hearse vehicles</h2>
      <p>
        This gallery includes our Renault Magnum truck hearse and ERF EC12 lorry hearse, both available for specialist funeral transport across the UK mainland.
        These vehicles are often chosen for funerals where the final journey should reflect a life connected to haulage, recovery, transport, engineering or road life.
      </p>
      <p style="margin-bottom:0;">
        For more information, you can also visit our
        <a href="/renault-magnum-hearse">Renault Magnum page</a>,
        <a href="/erf-ec12-hearse">ERF EC12 page</a>,
        <a href="/lorry-hearse-hire-uk">Lorry hearse hire UK page</a>
        and our <a href="/truck-hearse-vs-traditional-hearse">truck hearse vs traditional hearse guide</a>.
      </p>
    </div>

    <div class="card gallery-section-card gallery-narrow-card">
      <h2 class="gallery-section-title">Explore more</h2>
      <div class="gallery-info-grid">
        <div>
          <h3>Case Studies</h3>
          <p>Read recent updates showing our hearses out in the field on real funeral work.</p>
          <p><a class="btn" href="/case-studies">View case studies</a></p>
        </div>

        <div>
          <h3>Frequently Asked Questions</h3>
          <p>Find answers about coverage, bookings, vehicle choice and funeral director arrangements.</p>
          <p><a class="btn" href="/faq">View FAQ</a></p>
        </div>

        <div>
          <h3>Contact Us</h3>
          <p>Need availability, pricing guidance or help choosing the most suitable specialist vehicle?</p>
          <p><a class="btn" href="/contact">Enquire</a></p>
        </div>
      </div>
    </div>

  <% } %>
</div>

<%- include('partials/footer') %>

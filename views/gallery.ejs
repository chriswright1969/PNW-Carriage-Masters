<%- include('partials/head', { title }) %>
<%- include('partials/header') %>

<%
  const items = (media || []).filter(m => m.type === "image");
  const first = items[0];
%>

<div class="wrap gallery">
  <div class="gallery-main">
    <% if (first) { %>
      <img id="galleryMain" src="/uploads/<%= first.filename %>" alt="<%= first.caption || 'Gallery image' %>">
    <% } else { %>
      <div class="card"><div class="muted">No gallery images yet.</div></div>
    <% } %>
  </div>

  <% if (items.length) { %>
    <div class="gallery-strip" id="galleryStrip">
      <% items.forEach((it, idx) => { %>
        <button class="gthumb <%= idx===0 ? 'active' : '' %>"
                type="button"
                data-src="/uploads/<%= it.filename %>"
                data-alt="<%= (it.caption || 'Gallery image') %>">
          <img src="/uploads/<%= it.filename %>" alt="">
        </button>
      <% }) %>
    </div>
  <% } %>

  <div style="margin-top:16px">
    <a class="btn" href="/contact">Enquire</a>
  </div>
</div>

<script src="/js/gallery.js" defer></script>

<%- include('partials/footer') %>

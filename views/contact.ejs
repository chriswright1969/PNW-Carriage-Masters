<%- include('partials/head', { title }) %>
<%- include('partials/header') %>

<%
  const _form = (typeof form !== "undefined" && form) ? form : {};
  const v = (k) => String(_form[k] ?? "");
%>

<div class="wrap">
  <div class="card">
    <h1 class="section-title"><%= pageTitle %></h1>
    <div><%- contentHtml %></div>

    <hr/>

    <% if (success) { %>
      <div class="notice ok">Thank you — your message has been sent. We’ll respond as soon as possible.</div>
      <div style="height:10px"></div>
    <% } %>
    <% if (error && error.length) { %>
      <div class="notice bad"><%= error %></div>
      <div style="height:10px"></div>
    <% } %>

    <div class="grid-3">
      <div class="notice">
        <div class="small muted">Phone</div>
        <div><a href="tel:<%= settings.phone.replace(/\s/g,'') %>"><%= settings.phone %></a></div>
      </div>
    </div>

    <hr/>

    <h2 class="section-title">Send an enquiry</h2>

    <form action="/contact" method="post">
      <!-- Honeypot (bots fill this; humans won't see it) -->
      <div style="position:absolute; left:-9999px; width:1px; height:1px; overflow:hidden;">
        <label for="website">Website</label>
        <input id="website" name="website" type="text" tabindex="-1" autocomplete="off" value="">
      </div>

      <div class="grid-3">
        <div>
          <label for="first_name">First name *</label>
          <input id="first_name" name="first_name" type="text" required maxlength="60" autocomplete="given-name" value="<%= v('first_name') %>"/>
        </div>
        <div>
          <label for="last_name">Surname *</label>
          <input id="last_name" name="last_name" type="text" required maxlength="60" autocomplete="family-name" value="<%= v('last_name') %>"/>
        </div>
        <div>
          <label for="phone">Telephone *</label>
          <input id="phone" name="phone" type="tel" required maxlength="40" autocomplete="tel" value="<%= v('phone') %>"/>
        </div>
      </div>

      <label for="email">Email *</label>
      <input id="email" name="email" type="email" required maxlength="120" autocomplete="email" value="<%= v('email') %>"/>

      <label for="message">Message (optional)</label>
      <textarea id="message" name="message" rows="5" maxlength="1200"
        placeholder="Tell us about the service date, pickup location, and vehicle preference (if known)."><%= v('message') %></textarea>

      <div style="height:10px"></div>
      <button class="btn" type="submit">Send</button>
      <div class="small muted" style="margin-top:10px">We’ll use your details only to respond to this enquiry.</div>
    </form>

  </div>
</div>

<%- include('partials/footer') %>

<div class="wrap">
  <%- include('partials/breadcrumbs', { breadcrumbs }) %>

  <div class="card">
    <h1 style="color: var(--accent);">Truck Hearse Case Studies</h1>
    <p class="lead">
      Read recent truck hearse and lorry hearse case studies showing our specialist funeral vehicles out in the field on completed services across the UK.
      These updates include funeral work involving our ERF EC12 and Renault Magnum vehicles.
    </p>

    <p>
      We are honoured to serve our customers and their loved ones, and always aim to provide a first-class service with dignity and professionalism.
      Our priority is to help create a final journey that is personal, fitting and respectful.
    </p>

    <div class="cta" style="margin:18px 0 8px;">
      <a class="btn" href="/contact">Enquire</a>
      <a class="btn" href="/gallery">View gallery</a>
      <a class="btn" href="/faq">FAQ</a>
      <% if (phoneTel) { %>
        <a class="btn" href="tel:<%= phoneTel %>">Call <%= phoneRaw %></a>
      <% } %>
    </div>
  </div>

  <section class="case-studies-list" aria-label="Truck hearse case studies">
    <% caseStudies.forEach(study => { %>
      <article class="card case-study" id="<%= study.slug %>">
        <h2 class="section-title case-study-title"><%= study.title %></h2>

        <% if (study.date || study.vehicle) { %>
          <div class="case-study-meta-wrap" style="margin:0 0 10px;">
            <% if (study.date) { %>
              <p class="small muted case-study-meta" style="margin:0 0 4px;">
                Date:
                <time datetime="<%= study.isoDate || '' %>"><%= study.date %></time>
              </p>
            <% } %>

            <% if (study.vehicle) { %>
              <p class="small muted case-study-meta" style="margin:0;">
                Vehicle: <%= study.vehicle %>
              </p>
            <% } %>
          </div>
        <% } %>

        <div class="rich case-study-copy">
          <%- study.textHtml %>
        </div>

        <% if (study.image && study.image.file) { %>
          <div class="case-study-gallery">
            <figure class="case-study-photo">
              <a
                href="/images/<%= study.image.file %>"
                target="_blank"
                rel="noopener noreferrer"
                aria-label="Open larger image: <%= study.image.alt %>"
                title="<%= study.image.alt %>"
              >
                <img
                  src="/images/<%= study.image.file %>"
                  alt="<%= study.image.alt %>"
                  loading="lazy"
                  decoding="async"
                >
              </a>

              <% if (study.image.caption) { %>
                <figcaption class="small muted" style="margin-top:8px;">
                  <%= study.image.caption %>
                </figcaption>
              <% } %>
            </figure>
          </div>
        <% } %>
      </article>
    <% }) %>
  </section>

  <div class="card" style="margin-top:20px;">
    <h2 class="section-title" style="color: var(--accent);">Current specialist vehicles</h2>
    <div class="rich">
      <p><a href="/renault-magnum-hearse">Renault Magnum hearse</a></p>
      <p><a href="/erf-ec12-hearse">ERF EC12 hearse</a></p>
      <p><a href="/lorry-hearse-hire-uk">Lorry hearse hire across the UK</a></p>
      <p><a href="/truck-hearse-vs-traditional-hearse">Truck hearse vs traditional hearse</a></p>
    </div>
  </div>
</div>

<%- include('partials/footer') %>

<%
  const breadcrumbs = [
    { name: "Home", href: "/" },
    { name: "Case Studies", href: "/case-studies" }
  ];
%>

<%- include('partials/head', {
  title,
  metaTitle: 'Truck Hearse Case Studies | Completed Funeral Services',
  metaDescription: 'Read truck hearse case studies and recent field updates showing Renault Magnum and ERF EC12 specialist funeral services across the UK.',
  canonicalPath: 'case-studies',
  breadcrumbs
}) %>

<%- include('partials/header') %>

<%
  const s = settings || {};
  const phoneRaw = String(s.phone || "").trim();
  const phoneTel = phoneRaw.replace(/\s+/g, "");

  const caseStudies = [
    {
      title: "Baguley, Manchester",
      date: "26 March 2026",
      vehicle: "ERF EC12 Truck Hearse",
      textHtml: `
        <p>
          Our ERF EC12 truck hearse was recently involved in a funeral service in Baguley, Manchester,
          working alongside <a href="https://www.facebook.com/coopfuneralcare" target="_blank" rel="noopener noreferrer">Co-op Funeralcare</a>,
          with assistance from <a href="https://www.facebook.com/yolofuneralservices" target="_blank" rel="noopener noreferrer">Yolo Funeral Services</a>,
          for a final journey to <a href="https://www.facebook.com/profile.php?id=61583215632929" target="_blank" rel="noopener noreferrer">Manchester Crematorium</a>.
        </p>
      `,
      image: {
        file: "baguley-manchester-1.jpg",
        alt: "ERF EC12 truck hearse at a funeral service in Baguley, Manchester"
      }
    },
    {
      title: "Rushden,Northamptonshire",
      date: "13 March 2026",
      vehicle: "ERF EC12 Truck Hearse",
      textHtml: `
        <p>
          Working with the lovely Independent Family Funeral Directors
          <strong>A Abbotts &amp; Sons</strong>, the truck hearse was used for the final journey of a much-loved HGV driver
          to <a href="https://www.facebook.com/Nenevalleycrem" target="_blank" rel="noopener no referrer">Nene Valley Crematorium</a>.
        </p>
      `,
      image: {
        file: "northamptonshire-1.jpg",
        alt: "Truck hearse attending a funeral service in Northamptonshire"
      }
    },
    {
      title: "Selston, Nottingham",
      date: "8 March 2026",
      vehicle: "ERF EC12 Truck Hearse",
      textHtml: `
        <p>
          Thank you Team <a href="https://www.facebook.com/GillottsFuneralDirectors" target="_blank" rel="noopener no referrer">Gillotts</a> in Selston, 
          for making us so very welcome with the truck hearse. It was lovely working with you all. 
        </p>
      `,
      image: {
        file: "nottingham-1.jpg",
        alt: "Truck hearse taking part in a funeral service in Nottingham"
      }
    },
    {
      title: "Doncaster",
      date: "28 March 2026",
      vehicle: "ERF EC12 Truck Hearse",
      textHtml: `
        <p>
          After travelling to Doncaster the truck hearse had to be washed and prepared ready for service...
          it was a wet and cold day and it's not a 5 min job...but you only get one chance with the final journey...
          and it's got to be right...in more ways than one. Thanks for the tea to keep us warm Kevin...it was great to meet you!
        </p>
      `,
      image: {
        file: "doncaster-1.jpg",
        alt: "ERF EC12 attending a funeral in Doncaster"
      }
    }
  ];
%>

<div class="wrap">
<%- include('partials/breadcrumbs', { breadcrumbs }) %>
  <div class="card">
    <h1 style="color: var(--accent);">Our Truck and Lorry Hearses Out In The Field</h1>
    <p class="lead">
      We are honoured to serve our customers and their loved ones, and will always provide a first class service
      with dignity and professionalism. Our number one priority is our customers and their wishes for a final journey.
    </p>

    <div class="cta" style="margin:18px 0 8px;">
      <a class="btn" href="/contact">Enquire</a>
      <a class="btn" href="/gallery">View gallery</a>
      <a class="btn" href="/faq">FAQ</a>
      <% if (phoneTel) { %>
        <a class="btn" href="tel:<%= phoneTel %>">Call <%= phoneRaw %></a>
      <% } %>
    </div>
  </div>

  <section class="case-studies-list">
    <% caseStudies.forEach(study => { %>
      <article class="card case-study">
        <h2 class="section-title case-study-title"><%= study.title %></h2>

        <% if (study.date) { %>
          <p class="small muted case-study-meta" style="margin:0 0 4px;">
            Date: <%= study.date %>
          </p>
        <% } %>

        <% if (study.vehicle) { %>
          <p class="small muted case-study-meta">
            Vehicle: <%= study.vehicle %>
          </p>
        <% } %>

        <div class="rich case-study-copy">
          <%- study.textHtml %>
        </div>

        <% if (study.image && study.image.file) { %>
          <div class="case-study-gallery">
            <figure class="case-study-photo">
              <a href="/images/<%= study.image.file %>" target="_blank" rel="noopener noreferrer">
                <img
                  src="/images/<%= study.image.file %>"
                  alt="<%= study.image.alt %>"
                  loading="lazy"
                >
              </a>
            </figure>
          </div>
        <% } %>
      </article>
    <% }) %>
  </section>

  <div class="card" style="margin-top:20px;">
    <h2 class="section-title" style="color: var(--accent);">Current specialist vehicles</h2>
    <div class="rich">
      <p><a href="/renault-magnum-hearse">Renault Magnum hearse</a></p>
      <p><a href="/erf-ec12-hearse">ERF EC12 hearse</a></p>
      <p><a href="/lorry-hearse-hire-uk">Lorry hearse hire across the UK</a></p>
      <p><a href="/truck-hearse-vs-traditional-hearse">Truck hearse vs traditional hearse</a></p>
    </div>
  </div>
</div>

<%- include('partials/footer') %>

<%- include('partials/head', {
  title,
  metaTitle,
  metaDescription,
  canonicalPath
}) %>

<%- include('partials/header') %>

<%
  const s = settings || {};
  const phoneRaw = String(s.phone || "").trim();
  const phoneTel = phoneRaw.replace(/\s+/g, "");
%>

<div class="wrap">
  <div class="card">
    <h1 style="color: var(--accent);">Our Truck and Lorry Hearses Out In The Field.</h1>
    <p class="lead">
      We are honoured to serve our customers and their loved ones, and will always provide a first class service with dignity and professionalism.
      Our number One priority is our customers and their wishes for a final journey.
    </p>

    <div class="cta" style="margin:18px 0 8px;">
      <a class="btn" href="/contact">Enquire</a>
      <a class="btn" href="/gallery">View gallery</a>
      <a class="btn" href="/faq">FAQ</a>
      <% if (phoneTel) { %>
        <a class="btn" href="tel:<%= phoneTel %>">Call <%= phoneRaw %></a>
      <% } %>
    </div>
  </div>

 <div class="card case-study" style="margin-top:20px;">
  <h2 class="section-title" style="color: var(--accent); margin-bottom:8px;">
    Baguley, Manchester
  </h2>

  <p class="small muted" style="margin:0 0 14px;">
    Vehicle: ERF EC12 Truck Hearse
  </p>

  <div class="rich">
    <p>
      Our ERF EC12 truck hearse was recently involved in a funeral service in Baguley, Manchester, 
      working alongside <a href="https://www.facebook.com/coopfuneralcare" target="_blank" rel="noopener noreferrer">Co-op Funeralcare</a>,
      with assistance from <a href="https://www.facebook.com/yolofuneralservices" target="_blank" rel="noopener noreferrer">Yolo Funeral Services</a>,
      for a final journey to <a href="https://www.facebook.com/profile.php?id=61583215632929" target="_blank" rel="noopener noreferrer">Manchester Crematorium</a>.
    </p>
  </div>
  <div class="case-study-gallery">
    <figure class="case-study-photo">
      <a href="/uploads/baguley-manchester-1.jpg" target="_blank">
        <img
          src="/uploads/baguley-manchester-1.jpg"
          alt="ERF EC12 truck hearse at Baguley, Manchester funeral service"
        >
      </a>
    </figure>

    <figure class="case-study-photo">
      <a href="/uploads/baguley-manchester-2.jpg" target="_blank">
        <img
          src="/uploads/baguley-manchester-2.jpg"
          alt="Side view of ERF EC12 truck hearse in Baguley, Manchester"
        >
      </a>
    </figure>

    <figure class="case-study-photo">
      <a href="/uploads/baguley-manchester-3.jpg" target="_blank">
        <img
          src="/uploads/baguley-manchester-3.jpg"
          alt="ERF EC12 truck hearse arriving at Manchester Crematorium"
        >
      </a>
    </figure>
  </div>
</div>

  <div class="card" style="margin-top:20px;">
    <h2 class="section-title" style="color: var(--accent);">What future case studies will include</h2>
    <div class="rich">
      <p>
       Working with a lovely Independent Family Funeral Directors today A Abbotts & Sons with the truck hearse. Final journey for the much loved HGV Driver was to Nene Valley Crematorium
      </p>
    </div>
  </div>

  <div class="card" style="margin-top:20px;">
    <h2 class="section-title" style="color: var(--accent);">Current specialist vehicles</h2>
    <div class="rich">
      <p><a href="/renault-magnum-hearse">Renault Magnum hearse</a></p>
      <p><a href="/erf-ec12-hearse">ERF EC12 hearse</a></p>
      <p><a href="/lorry-hearse-hire-uk">Lorry hearse hire across the UK</a></p>
      <p><a href="/truck-hearse-vs-traditional-hearse">Truck hearse vs traditional hearse</a></p>
    </div>
  </div>

  <div class="card" style="margin-top:20px;">
    <h2 class="section-title" style="color: var(--accent);">Preparing real completed service write-ups</h2>
    <div class="rich">
      <p>
        One of our truck hearses over to Nottingham today with Co-op Funeralcare 
        Lovely to work with Funeral Director Cherie and Thanks to Chess for her arrangements which included a stop-off at the Wagon & Horses for locals to raise a glass and then 
        give a round of applause as the cortege left the pub one last time. RIP Andy.
      </p>
    </div>
  </div>

</div>

<%- include('partials/footer') %>

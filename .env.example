# ---- REQUIRED (production) ----
SESSION_SECRET=change-me-to-a-long-random-string
SETUP_TOKEN=change-me-to-a-random-setup-token

# Public hostname used for default email From address
PUBLIC_HOST=truckhearse.co.uk

# ---- SMTP (required to forward contact form) ----
# Use an SMTP provider (e.g., Microsoft 365, Google Workspace, Mailgun, etc.)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# ---- Persistent storage ----
# On Render, set DATA_DIR=/var/data
DATA_DIR=./data
DB_PATH=
UPLOAD_DIR=
